{
  "name": "@mongoosejs/typescript-express-reviews",
  "description": "Mongoose vehicle review sample app with TypeScript and Express",
  "authors": "Valeri Karpov <val@karpov.io>",
  "version": "1.0.0",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "clean-db": "tsx --env-file=.env src/seed/dropCollections.ts",
    "seed": "tsx --env-file=.env src/seed/seed.ts",
    "start": "tsx --env-file=.env src/api/index.ts",
    "test": "tsx --env-file=.env.test ./node_modules/mocha/bin/mocha.js tests/*.test.ts"
  },
  "engines": {
    "node": ">=20.6.0"
  },
  "dependencies": {
    "@awaitjs/express": "0.9.0",
    "@datastax/astra-mongoose": "1.4.1",
    "bcryptjs": "^3.0.0",
    "express": "4.x",
    "mongoose": "^9.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/body-parser": "^1.19.2",
    "@types/express": "4.17.21",
    "@types/mocha": "10.0.10",
    "@types/node": "26.1.1",
    "mocha": "11.7.6",
    "sinon": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "7.0.2"
  }
}
